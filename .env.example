# Odin Configuration
# Copy to .env and fill in your values

# ===== LLM Provider =====
# Choose one: lmstudio, openrouter, openai, ollama, default

# Option 1: LM Studio (local, free)
# ODIN_LLM_PROVIDER=lmstudio
# ODIN_LMSTUDIO_BASE_URL=http://localhost:1234/v1
# ODIN_LMSTUDIO_MODEL=qwen2.5-coder-32b

# Option 2: OpenRouter (BYOK)
# ODIN_LLM_PROVIDER=openrouter
# ODIN_OPENROUTER_API_KEY=sk-or-v1-...
# ODIN_OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Option 3: OpenAI
# ODIN_LLM_PROVIDER=openai
# ODIN_LLM_API_KEY=sk-...
# ODIN_LLM_MODEL=gpt-4o-mini

# Option 4: Ollama (local, free)
# ODIN_LLM_PROVIDER=ollama
# ODIN_OLLAMA_MODEL=qwen2.5-coder

# Option 5: Default / custom (original behaviour)
ODIN_ANTHROPIC_API_KEY=sk-ant-...
ODIN_LLM_MODEL=claude-sonnet-4-20250514

# ===== GitHub Webhook =====
# ODIN_GITHUB_TOKEN=ghp_...
# ODIN_GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ===== Infrastructure =====
ODIN_REDIS_URL=redis://localhost:6379/0
ODIN_LOG_LEVEL=INFO

# ===== Rules Engine =====
# ODIN_RULES_ENABLED=true
# ODIN_RULES_COMPLEXITY_THRESHOLD=10
# ODIN_RULES_FUNCTION_LENGTH_THRESHOLD=50
